# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — used only by integration tests to create/delete test users
# without hitting email rate limits. NEVER expose this client-side.
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Encryption (required) ─────────────────────────────────────────────────────
# Random secret used to encrypt user API keys at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=change-me-to-a-random-32-char-secret

# ── LLM Provider API Keys (optional — users add their own via the UI) ─────────
# Only set these if you want server-side defaults; normally left blank.
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...
# GOOGLE_AI_API_KEY=AIzaSy...
# MISTRAL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MCP Server credentials (optional) ────────────────────────────────────────
# BRAVE_SEARCH_API_KEY=BSA...
# GITHUB_TOKEN=github_pat_...
# NOTION_TOKEN=secret_...
# SLACK_BOT_TOKEN=xoxb-...

# ── Database (optional — only needed for direct pg access in dev/scripts) ─────
# DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
